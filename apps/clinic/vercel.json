{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && npm install",
  "buildCommand": "cd ../.. && npm run build:clinic",
  "framework": "nextjs",
  "env": {
    "DEV_BYPASS_OTP": "true",
    "NEXT_PUBLIC_OTP_BYPASS_HINT": "true"
  },
  "crons": [
    {
      "path": "/api/cron/appointment-reminders",
      "schedule": "0 7 * * *"
    }
  ]
}
