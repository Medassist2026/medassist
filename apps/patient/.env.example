# =============================================================================
# MedAssist Patient App — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp apps/patient/.env.example apps/patient/.env.local
#
# Production / Preview / Staging envs are configured per-Vercel-project (the
# medassist-patient Vercel project). See apps/patient/vercel.json for the
# baseline. Per-env splits (real OTP vs bypass) are documented below.

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api
# Staging project: medassist-egypt (mtmdotixlhwksyoordbl)
# Production project: provisioned during Phase L
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_APP_URL: production patient-app domain.
# Placeholder until L-5 (Mo wall-time) lands the real domain.
NEXT_PUBLIC_APP_URL=http://localhost:3002

# -----------------------------------------------------------------------------
# OTP Behavior (per-environment)
# -----------------------------------------------------------------------------
# Production:        DEV_BYPASS_OTP unset (or false). Real SMS via vendor.
# Preview / Staging: DEV_BYPASS_OTP=true. Bypass for testing convenience.
# Local dev:         DEV_BYPASS_OTP=true.
DEV_BYPASS_OTP=true

# NEXT_PUBLIC_OTP_BYPASS_HINT: when true, the UI shows the dev-bypass hint
# next to OTP inputs. Only set true in preview/staging/local.
NEXT_PUBLIC_OTP_BYPASS_HINT=true

# OTP_BYPASS_CODE: server-side override code accepted when DEV_BYPASS_OTP=true.
# Leave unset to fall back to the default bypass code documented in the
# auth handlers.
# OTP_BYPASS_CODE=

# -----------------------------------------------------------------------------
# SMS Gateway (vendor adapter; see SmsGateway interface)
# -----------------------------------------------------------------------------
# Vendor procurement is L-2 Mo wall-time. When DEV_BYPASS_OTP=true, no SMS
# is sent (ConsoleLogSmsGateway used). When false, the configured vendor
# adapter must be wired or registration / OTP endpoints will error.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
NATIONAL_ID_SALT=generate_a_random_32_char_string
RATE_LIMIT_KEY_SECRET=generate_a_random_32_char_string

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# FEATURE_PHONE_CHANGE_V2: dual-OTP phone-change flow (see audits/phase
# rollout notes). Server-only.
FEATURE_PHONE_CHANGE_V2=false

# -----------------------------------------------------------------------------
# Observability (Optional)
# -----------------------------------------------------------------------------
# Set in production to enable Sentry error tracking (Bundle 6 / L-4).
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Cron auth (server-only) — patient app has no crons today; reserved for future.
# -----------------------------------------------------------------------------
# CRON_SECRET=
