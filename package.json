{
  "name": "medassist",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:clinic": "npm run dev -w @medassist/clinic",
    "dev:patient": "npm run dev -w @medassist/patient",
    "build": "next build",
    "build:clinic": "npm run build -w @medassist/clinic",
    "build:patient": "npm run build -w @medassist/patient",
    "start": "next start",
    "lint": "eslint .",
    "lint:scopes": "eslint --config eslint.config.scopes.mjs --no-config-lookup --quiet 'packages/shared/lib/**/*.{ts,tsx}' 'apps/clinic/app/**/*.{ts,tsx}' 'apps/patient/app/**/*.{ts,tsx}'",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@sentry/nextjs": "^10.38.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "date-fns": "^3.3.1",
    "framer-motion": "^11.0.3",
    "fuse.js": "^7.0.0",
    "lucide-react": "^0.344.0",
    "nanoid": "^5.0.5",
    "next": "15.5.18",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.0.1",
    "@eslint/eslintrc": "^3.3.5",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.18",
    "eslint-plugin-medassist-local": "file:./eslint-rules",
    "husky": "^9.1.7",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
