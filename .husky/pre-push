#!/usr/bin/env sh
# ----------------------------------------------------------------------------
# pre-push: gate `git push` on clean type-checks + admin-scope discipline
# for the whole monorepo.
#
# Why this exists: commit b724eb1 widened a data-layer signature without
# updating the call site, and the broken code reached Vercel because nothing
# ran `tsc --noEmit` between the commit and the push. CI runs type-check on
# push, but Vercel builds in parallel — by the time CI fails, Vercel has
# already failed too. This hook closes that gap locally.
#
# Three passes (D-042 + D-045 + D-008 Amendment 2026-05-09):
#   1. Root tsc --noEmit  — catches phantom imports inside packages/shared/**
#      that the per-workspace check misses (its tsconfig only sees
#      apps/clinic/**). This is the gate that would have flagged the
#      Capacitor TS2307 errors that lived for ~6 weeks unseen.
#   2. Clinic-workspace type-check — fast feedback on app-specific errors.
#   3. Admin-scope discipline (lint:scopes) — runs the custom eslint rule
#      `medassist-local/no-unregistered-admin-scope` across packages/shared/lib
#      + apps/{clinic,patient}/app. Fails the push if any callsite uses (a) a
#      static-string scope not in `ALLOWED_ADMIN_SCOPES`, or (b) a non-static
#      argument (template literal / variable / expression). Per-app `next lint`
#      catches app code only — this pass is what enforces the discipline on
#      shared package callsites. Phase 2 of D-008 Amendment 2026-05-08's
#      Option D plan.
#
# Skip with: git push --no-verify   (use sparingly, e.g. WIP branches)
# ----------------------------------------------------------------------------

set -e

# Pass 1: root — wide scope, catches monorepo-wide drift (D-045).
echo "→ pre-push: root tsc --noEmit (full monorepo)"
npm run type-check

# Pass 2: clinic workspace — fast app-scoped feedback (D-042).
echo "→ pre-push: type-check clinic workspace"
npm run type-check -w @medassist/clinic

# Pass 3: admin-scope discipline — eslint rule across shared + apps
# (D-008 Amendment 2026-05-09 / Phase F Task 20).
echo "→ pre-push: lint:scopes (admin-scope discipline)"
npm run lint:scopes
