From 3ec78ff78194297601f049854c943d879275b0ac Mon Sep 17 00:00:00 2001
From: Mo Badwy <badwy.mt@gmail.com>
Date: Mon, 23 Mar 2026 23:11:02 -0700
Subject: [PATCH 1/2] fix(sms): detect placeholder Twilio creds + add 6s fetch
 timeout

Prevents serverless functions from hanging indefinitely when Twilio
credentials are unset or contain placeholder values (your_twilio_*).
SMS is now stubbed gracefully in both cases instead of making a real
HTTP call that times out after Vercel's function limit.

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>
---
 packages/shared/lib/sms/twilio-client.ts | 12 ++++++++++++
 1 file changed, 12 insertions(+)

diff --git a/packages/shared/lib/sms/twilio-client.ts b/packages/shared/lib/sms/twilio-client.ts
index c52b523..0ffab8b 100644
--- a/packages/shared/lib/sms/twilio-client.ts
+++ b/packages/shared/lib/sms/twilio-client.ts
@@ -16,6 +16,17 @@ export async function sendSMS(to: string, body: string): Promise<SMSResult> {
     return { success: true, sid: `stub_${Date.now()}` }
   }
 
+  // Detect placeholder credentials — avoid real Twilio call
+  if (
+    authToken === 'your_twilio_auth_token' ||
+    fromNumber === 'your_twilio_phone_number' ||
+    authToken?.startsWith('your_') ||
+    fromNumber?.startsWith('your_')
+  ) {
+    console.warn('[Twilio] Placeholder credentials detected — SMS stubbed')
+    return { success: true, sid: `stub_${Date.now()}` }
+  }
+
   try {
     const response = await fetch(
       `${TWILIO_API_URL}/Accounts/${accountSid}/Messages.json`,
@@ -30,6 +41,7 @@ export async function sendSMS(to: string, body: string): Promise<SMSResult> {
           From: fromNumber,
           Body: body,
         }).toString(),
+        signal: AbortSignal.timeout(6000), // 6s max — don't hang the serverless function
       }
     )
 
-- 
