# L-7 (2026-05-16): Next 14→15 + React 18→19 migration.
#
# Several runtime dependencies haven't yet shipped peer-dependency
# declarations that include React 19, even though they work fine at
# runtime under it. Specifically:
#   - lucide-react@0.344.0 (peer: ^16.5.1 || ^17.0.0 || ^18.0.0)
#   - cmdk (older versions; we bumped to ^1.1.1 which is fine)
#   - a handful of @radix-ui/* transitive deps
#
# npm 7+ enforces peer-dep resolution strictly by default. Setting
# legacy-peer-deps=true tells npm to use npm 6 behavior — warn instead
# of error on peer conflicts. This is the standard escape hatch when
# upstream peer ranges lag the React major; it does NOT change which
# packages get installed.
#
# When all relevant deps ship React 19 peer support, this can be removed.
legacy-peer-deps=true
